# =============================================================================
# OpenCode Dockerfile - Server Mode with Groq API
# =============================================================================
# Multi-stage build for minimal image size
# 
# Security features:
#   - Non-root user (node:node, UID 1000)
#   - No new privileges
#   - Dropped Linux capabilities
# =============================================================================

# syntax=docker/dockerfile:1-labs

# =============================================================================
# Stage 1: Download binary
# =============================================================================
FROM alpine:3.19 AS downloader

RUN apk add --no-cache curl tar

ARG TARGETARCH
ARG TARGETOS

# Verify checksum for security (update SHA256 with value from GitHub release)
ARG OPENCODE_SHA256=""
RUN curl -fsSL "https://github.com/anomalyco/opencode/releases/latest/download/opencode-linux-x64-musl.tar.gz" -o /tmp/opencode.tar.gz && \
    if [ -n "$OPENCODE_SHA256" ]; then \
        echo "${OPENCODE_SHA256}  /tmp/opencode.tar.gz" | sha256sum -c - || exit 1; \
    fi && \
    tar -xzf /tmp/opencode.tar.gz -C /usr/local/bin && \
    chmod +x /usr/local/bin/opencode && \
    rm /tmp/opencode.tar.gz

# =============================================================================
# Stage 2: Production
# =============================================================================
FROM alpine:3.19

RUN apk add --no-cache \
    dumb-init \
    ca-certificates \
    gcompat \
    libstdc++

COPY --from=downloader /usr/local/bin/opencode /usr/local/bin/opencode

RUN mkdir -p /home/node/.config/opencode && \
    addgroup -S node && adduser -S node -G node && \
    chown -R node:node /home/node

USER node
WORKDIR /home/node

EXPOSE 4096

ENV HOME=/home/node \
    PATH=/usr/local/bin:$PATH

ENTRYPOINT ["dumb-init", "--"]

CMD ["opencode", "serve", "--hostname", "0.0.0.0", "--port", "4096"]
