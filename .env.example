# Секреты БД (ЗАПОЛНИТЕ СВОИМИ ЗНАЧЕНИЯМИ)
DB_USER=your_db_user
DB_PASSWORD=your_secure_password_here
DB_NAME=paperclip_prod

# Ключи AI провайдеров (обязательно для работы агентов)
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# Настройки масштабируемости
# Paperclip поддерживает изоляцию данных для нескольких компаний в одной инсталляции
MULTI_COMPANY_MODE=true
