# =============================================================================
# Paperclip Docker Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://paperclip:changeme@db:5432/paperclip

# Database credentials (for docker-compose with embedded DB)
POSTGRES_USER=paperclip
# Generate secure password with: openssl rand -hex 32
POSTGRES_PASSWORD=changeme_secure_password_here
POSTGRES_DB=paperclip

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# Secret key for session encryption (auto-generated if not set)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# =============================================================================
# AI PROVIDER API KEYS (Free tier)
# =============================================================================

# Groq API - Free tier with fast inference
# Get your key at: https://console.groq.com/keys
# Models: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it
GROQ_API_KEY=

# OpenAI API (optional, for development)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API (optional, for development)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenCode Server Configuration
# Basic auth: username=opencode, password=<your_password>
OPENCODE_API_PASSWORD=

# OpenCode server port (default: 4096)
OPENCODE_SERVER_PORT=4096

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
# Paperclip home directory (where data is stored)
PAPERCLIP_HOME=/paperclip

# Public URL for webhooks and callbacks
PAPERCLIP_PUBLIC_URL=https://paperclip.example.com

# Instance ID (useful for multi-instance deployments)
PAPERCLIP_INSTANCE_ID=home-server

# Configuration file path
PAPERCLIP_CONFIG=/paperclip/instances/default/config.json

# Deployment mode: unauthenticated, authenticated
PAPERCLIP_DEPLOYMENT_MODE=authenticated

# Deployment exposure: private, vpn, public
PAPERCLIP_DEPLOYMENT_EXPOSURE=vpn

# Allowed hostnames for Paperclip (comma-separated)
# Use your server's local IP or domain name
PAPERCLIP_ALLOWED_HOSTNAMES=localhost,127.0.0.1,192.168.1.100

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Server port
PORT=3100

# Server host (bind to all interfaces)
HOST=0.0.0.0

# Serve UI from the same server
SERVE_UI=true

# Node environment
NODE_ENV=production

# =============================================================================
# LOGGING & MONITORING
# =============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================
# Redis for session storage (optional)
REDIS_URL=redis://redis:6379

# S3-compatible storage for file uploads (optional)
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=



# =============================================================================
# GRAFANA MONITORING
# =============================================================================
# Server IP or hostname for local access
GRAFANA_DOMAIN=192.168.0.186

# Full URL for Grafana access
GRAFANA_ROOT_URL=http://192.168.0.186:3000

# Grafana admin password
# Generate with: openssl rand -hex 16
GRAFANA_PASSWORD=changeme_secure_password

# =============================================================================
# RESOURCE LIMITS (for docker-compose)
# =============================================================================
# CPU limit (cores)
CPU_LIMIT=2.0

# Memory limit (GB)
MEMORY_LIMIT=4G

# =============================================================================
# DEVELOPMENT SETTINGS (not for production)
# =============================================================================
# These variables are used by docker-compose.dev.yml, not production
# DEBUG=false
# SOURCE_MAP=true

# =============================================================================
# DATA DIRECTORIES
# =============================================================================
# Directory for Paperclip data (mapped to volume)
PAPERCLIP_DATA_DIR=./data/paperclip

# Directory for database data (mapped to volume)
POSTGRES_DATA_DIR=./data/postgres

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
# Directory for storing backups
BACKUP_DIR=./backups

# Backup retention in days (default: 90)
BACKUP_RETENTION_DAYS=90
